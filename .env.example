# ============================================
# RSSHub 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# --- 基础配置 ---
PORT=1200
# 缓存类型：memory（默认）或 redis
CACHE_TYPE=memory
# 缓存过期时间（秒），默认 5 分钟
CACHE_EXPIRE=300
# 内容缓存过期时间（秒），默认 1 小时
CACHE_CONTENT_EXPIRE=3600

# --- Twitter/X 认证配置（必须配置其中一种） ---

# 方式一（推荐）：使用 auth_token Cookie
# 获取方法：
#   1. 在浏览器中登录 x.com
#   2. 打开开发者工具 (F12) → Application → Cookies → x.com
#   3. 找到名为 "auth_token" 的 Cookie，复制其值
#   4. 可以配置多个（逗号分隔），RSSHub 会轮询使用
TWITTER_AUTH_TOKEN=your_auth_token_here

# 方式二：使用 Twitter Developer API（付费）
# 在 https://developer.twitter.com 创建 App 获取
# TWITTER_CONSUMER_KEY=your_consumer_key
# TWITTER_CONSUMER_SECRET=your_consumer_secret
# TWITTER_ACCESS_TOKEN=your_access_token（可选，用户级认证）
# TWITTER_ACCESS_SECRET=your_access_secret（可选）

# --- 可选配置 ---
# 代理（如果需要翻墙访问 Twitter）
# PROXY_URI=http://127.0.0.1:7890
# 日志级别
# LOGGER_LEVEL=info
